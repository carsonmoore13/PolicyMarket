# Backend
MONGO_URI=mongodb+srv://<username>:<password>@policymarket.r1fric0.mongodb.net/?appName=policymarket
MONGO_DB_NAME=elections_2026
PORT=3001
# Optional: first day candidates may file for TX ISD (school board) races shown in the sidebar (YYYY-MM-DD)
# SCHOOL_BOARD_FILING_OPENS_TX=2026-07-20
# Optional: first day candidates may file for mayoral races (YYYY-MM-DD)
# MAYOR_FILING_OPENS_TX=2026-07-18
# Optional: first day candidates may file for city council races (YYYY-MM-DD)
# CITY_COUNCIL_FILING_OPENS_TX=2026-07-18
# Optional: first calendar day (UTC) county Ballotpedia runtime–discovered locals appear in the API (YYYY-MM-DD).
# If unset, those candidates are shown immediately. Set e.g. 2026-08-18 to enforce post–filing visibility in production.
# COUNTY_RUNTIME_LOCALS_VISIBLE_ON_TX=2026-08-18
# Optional: set to 1 to always show county-runtime locals (overrides visibility dates)
# COUNTY_RUNTIME_BYPASS_FILING_GATE=1

# Frontend (Vite exposes VITE_ prefixed vars)
VITE_MAPBOX_TOKEN=your_mapbox_public_token_here
VITE_API_BASE_URL=http://localhost:3001

